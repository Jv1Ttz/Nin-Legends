generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(cuid())
  username     String      @unique
  passwordHash String
  createdAt    DateTime    @default(now())
  characters   Character[]
}

model Character {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  name          String
  clan          String        @default("")
  village       String
  element       String
  imageUrl      String?
  rank          String        @default("Estudante")
  level         Int           @default(1)
  xp            Int           @default(0)
  xpToNext      Int           @default(100)
  attrPoints    Int           @default(0)
  hp            Int           @default(100)
  maxHp         Int           @default(100)
  chakra        Int           @default(100)
  maxChakra     Int           @default(100)
  ninjutsu      Int           @default(5)
  taijutsu      Int           @default(5)
  genjutsu      Int           @default(5)
  velocidade    Int           @default(5)
  resistencia   Int           @default(5)
  inteligencia  Int           @default(5)
  jutsus        String        @default("[]")
  ryou          Int           @default(500)
  createdAt     DateTime      @default(now())
  inventory     InventoryItem[]
  sessions      GameSession[]
  missions      Mission[]
}

model InventoryItem {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id])
  name        String
  type        String
  description String
  quantity    Int       @default(1)
  effect      String    @default("{}")
}

model GameSession {
  id              String           @id @default(cuid())
  characterId     String
  character       Character        @relation(fields: [characterId], references: [id])
  currentLocation String           @default("Vila da Folha")
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  messages        MessageHistory[]
}

model MessageHistory {
  id        String      @id @default(cuid())
  sessionId String
  session   GameSession @relation(fields: [sessionId], references: [id])
  role      String
  content   String
  imageUrl  String?
  timestamp DateTime    @default(now())
}

model Mission {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id])
  rank        String
  title       String
  description String
  status      String    @default("available")
  xpReward    Int       @default(0)
  ryouReward  Int       @default(0)
  createdAt   DateTime  @default(now())
}
